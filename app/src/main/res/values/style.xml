<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme.Widget.Tv.Button" parent="AppTheme.Tv">
        <item name="android:background">@drawable/bg_button_tv</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textColor">@drawable/color_button_text</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="AppTheme.Widget.Mobile.Button" parent="AppTheme.Mobile">
        <item name="android:background">@drawable/bg_button_primary_netflix</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme.Widget.Mobile.Button.Secondary" parent="AppTheme.Widget.Mobile.Button">
        <item name="android:background">@drawable/bg_button_secondary_netflix</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Stile per forzare il fondo nero nelle schermate di impostazione (Leanback) -->
    <!-- Usiamo direttamente android:background nella preferenceTheme per non romper il build -->
    <style name="PreferenceThemeOverlay.Leanback.Amoled" parent="PreferenceThemeOverlayLeanback">
        <item name="android:windowBackground">?attr/app_background_color</item>
        <item name="android:colorBackground">?attr/app_background_color</item>
    </style>

</resources>
